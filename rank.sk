        set slot 9 of {_gui} to rankItem(player, "novize", leather chestplate, "&aNovize")
        set slot 11 of {_gui} to rankItem(player, "lehrling", leather leggings, "&aLehrling")
        set slot 13 of {_gui} to rankItem(player, "arbeiter", leather boots, "&aArbeiter")
        set slot 15 of {_gui} to rankItem(player, "geselle", stone pickaxe, "&aGeselle")
        set slot 17 of {_gui} to rankItem(player, "handwerker", iron pickaxe, "&aHandwerker")
        setNavButtons({_gui})
        open {_gui} to player

on inventory click:
