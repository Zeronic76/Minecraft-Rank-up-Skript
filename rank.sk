# ---------------------------------------------------------
#  KAUF-KOMMANDO: /buyrank <gruppe> (Mit strikter Upgrade-Prüfung)
# ---------------------------------------------------------
command /buyrank <text>:
    trigger:
        set {_group} to arg-1

        # 1. RANG-UPGRADE ÜBERPRÜFUNG
        # Wenn der Spieler den Rang schon hat, direkt abbrechen
        if player has permission "group.%{_group}%":
            send "&cDu besitzt den Rang &e%{_group}% &cbereits oder hast einen höheren Rang!" to player
            stop

        # Den Index des gewünschten Rangs in der Reihenfolge finden
        set {_targetIndex} to 0
        loop {rank.order::*}:
            if loop-value is {_group}:
                set {_targetIndex} to loop-index parsed as integer
                exit loop

        if {_targetIndex} is 0:
            send "&cDieser Rang existiert nicht im System!" to player
            stop

        # Den exakten Vorgänger-Rang ermitteln
        set {_requiredPreviousIndex} to {_targetIndex} - 1
        set {_requiredPreviousGroup} to {rank.order::%{_requiredPreviousIndex}%}

        # Prüfen, ob der Spieler den Vorgänger-Rang hat (Nutzt LuckPerms group-permission)
        if player does not have permission "group.%{_requiredPreviousGroup}%":
            send "&cDu kannst diesen Rang nicht kaufen! Du musst zuerst den Rang &e%{_requiredPreviousGroup}% &cbesitzen." to player
            stop

        # 2. PREIS- UND STATS-ÜBERPRÜFUNG (Deine bestehende Logik)
        set {_price} to {rank.%{_group}%.price}
        if {_price} is not set:
            set {_price} to 0

        set {_stats::*} to getPlayerStats(player)
        set {_rawPlay} to uncolored {_stats::1}
        set {_rawDist} to uncolored {_stats::2}
        set {_rawBlocks} to uncolored {_stats::3}

        replace all "," with "." in {_rawPlay}
        replace all "," with "." in {_rawDist}
        replace all "m" with "" in {_rawDist}
        replace all " " with "" in {_rawPlay}
        replace all " " with "" in {_rawDist}
        replace all " " with "" in {_rawBlocks}

        set {_playtime} to {_rawPlay} parsed as number
        set {_distance} to {_rawDist} parsed as number
        set {_blocks} to {_rawBlocks} parsed as number

        if {_playtime} is not set:
            set {_playtime} to 0
        if {_distance} is not set:
            set {_distance} to 0
        if {_blocks} is not set:
            set {_blocks} to 0

        set {_reqPlay} to {rank.%{_group}%.req.playtime}
        set {_reqDist} to {rank.%{_group}%.req.distance}
        set {_reqBlocks} to {rank.%{_group}%.req.blocks}

        if {_reqPlay} is set:
            if {_playtime} < {_reqPlay}:
                send "&cDu benötigst mindestens &e%{_reqPlay}%&c Stunden Spielzeit für &e%{_group}%&c! (Du hast: &e%{_playtime}%&c)"
                stop

        if {_reqDist} is set:
            if {_distance} < {_reqDist}:
                send "&cDu musst mindestens &e%{_reqDist}%&c Meter gelaufen sein für &e%{_group}%&c! (Du bist: &e%{_distance}%m&c)"
                stop

        if {_reqBlocks} is set:
            if {_blocks} < {_reqBlocks}:
                send "&cDu musst mindestens &e%{_reqBlocks}%&c Blöcke abgebaut haben für &e%{_group}%&c! (Du hast: &e%{_blocks}%&c)"
                stop

        if player's balance < {_price}:
            send "&cDu hast nicht genug Geld für &e%{_group}%&c! (&7Preis: &e%{_price}%&7)"
            stop

        # 3. KAUF DURCHFÜHREN
        remove {_price} from player's balance
        execute console command "lp user %player% parent set %{_group}%"
        send "&aDu hast erfolgreich den Rang &e%{_group}% &aerworben!"
