# ---------------------------------------------------------
#  FUNKTION: STATS AUS CMI-PLACEHOLDER EINLESEN (Escaped)
# ---------------------------------------------------------
function getPlayerStats(p: player) :: objects:
    set {_rawPlay} to placeholder "%%cmi_user_playtime_hourst%%" of {_p}
    set {_rawDist} to placeholder "%%cmi_user_stats_travel%%" of {_p}
    set {_rawBlocks} to placeholder "%%cmi_user_stats_blocksmined%%" of {_p}

    if {_rawPlay} is "" or "<none>":
        set {_rawPlay} to "0"
    if {_rawDist} is "" or "<none>":
        set {_rawDist} to "0m"
    if {_rawBlocks} is "" or "<none>":
        set {_rawBlocks} to "0"

    return {_rawPlay} and {_rawDist} and {_rawBlocks}

# ---------------------------------------------------------
#  HILFSFUNKTION: GUI-ITEM MIT TEXT-ANZEIGE
# ---------------------------------------------------------
function rankItem(p: player, group: text, mat: item, display: text) :: item:
    set {_stats::*} to getPlayerStats({_p})
    set {_playtimeText} to {_stats::1}
    set {_distanceText} to {_stats::2}
    set {_blocksText} to {_stats::3}

    set {_reqPlay} to {rank.%{_group}%.req.playtime}
    set {_reqDist} to {rank.%{_group}%.req.distance}
    set {_reqBlocks} to {rank.%{_group}%.req.blocks}
    set {_price} to {rank.%{_group}%.price}

    set {_item} to {_mat}
    set name of {_item} to {_display}

    set {_distSuffix} to ""
    if {_distanceText} does not contain "m":
        set {_distSuffix} to "m"

    set {_lore::*} to "&7Preis: &e%{_price}%"
    add "&7" to {_lore::*}
    add "&fSpielzeit: &e%{_playtimeText}% &7/ &e%{_reqPlay}%" to {_lore::*}
    add "&fStrecke: &e%{_distanceText}%%{_distSuffix}% &7/ &e%{_reqDist}%m" to {_lore::*}
    add "&fBlöcke: &e%{_blocksText}% &7/ &e%{_reqBlocks}%" to {_lore::*}

    set lore of {_item} to {_lore::*}
    return {_item}

# ---------------------------------------------------------
#  HILFSFUNKTION: NAVIGATIONS-BUTTONS (Zurück / Schließen)
# ---------------------------------------------------------
function setNavButtons(gui: inventory):
    set slot 27 of {_gui} to magenta glazed terracotta named "&d&l« Zurück"
    set slot 35 of {_gui} to barrier named "&c&l✕ Schließen"

# ---------------------------------------------------------
#  HAUPTMENÜ: LAUFBAHNEN
# ---------------------------------------------------------
command /ranks:
    trigger:
        set {_gui} to a new chest inventory with 4 rows named "&6&lRang-Laufbahnen"
        set slot 10 of {_gui} to leather helmet named "&aAnfänger"
        set slot 11 of {_gui} to stone axe named "&eSiedler"
        set slot 12 of {_gui} to golden helmet named "&9Adel"
        set slot 14 of {_gui} to diamond chestplate named "&bElite"
        set slot 15 of {_gui} to netherite sword named "&cHerrscher"
        set slot 16 of {_gui} to dragon head named "&5Unsterblichen"
        # Auch im Hauptmenü macht ein Close-Button auf der 35 Sinn!
        set slot 35 of {_gui} to barrier named "&c&l✕ Schließen"
        open {_gui} to player

on inventory click:
    name of event-inventory is "&6&lRang-Laufbahnen"
    cancel event
    if index of event-slot is 10:
        execute player command "ranks_anfaenger"
    else if index of event-slot is 11:
        execute player command "ranks_siedler"
    else if index of event-slot is 12:
        execute player command "ranks_adel"
    else if index of event-slot is 14:
        execute player command "ranks_elite"
    else if index of event-slot is 15:
        execute player command "ranks_herrscher"
    else if index of event-slot is 16:
        execute player command "ranks_unsterblichen"
    else if index of event-slot is 35:
        close player's inventory

